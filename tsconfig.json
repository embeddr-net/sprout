{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@embeddr/zen-shell": ["../embeddr-zen-shell/src/index.ts"],
      "@embeddr/zen-shell/*": ["../embeddr-zen-shell/src/*"],
      "@embeddr/react-ui": ["../embeddr-react-ui/src/index.tsx"],
      "@embeddr/react-ui/*": ["../embeddr-react-ui/src/*"]
    }
  },
  "include": ["src"]
}
